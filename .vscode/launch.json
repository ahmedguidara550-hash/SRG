{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ SRG Desktop (main)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    },
    {
      "name": "🌐 SRG Serveur Mobile (Flask)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/mobile_server.py",
      "console": "integratedTerminal",
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    },
    {
      "name": "🚀 SRG Complet (desktop + mobile)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/lancer.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    }
  ]
}